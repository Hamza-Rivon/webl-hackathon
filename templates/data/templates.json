{
  "version": "5.0.0",
  "templates": [
    {
      "id": "aroll-clean-then-broll",
      "name": "A-Roll Clean Then B-Roll",
      "description": "Record one continuous A-roll take with camera + mic first. The existing voiceover cleaning pipeline processes extracted audio, then you can add optional B-roll after cleanup.",
      "platform": "all",
      "language": "en",
      "durationTarget": 60,
      "editingRecipe": "aroll-clean-then-broll.json",
      "canonicalScript": "Record your full talking-head take in one pass while reading your script. After audio cleanup, add optional B-roll clips for visual alternation.",
      "scriptStructure": {
        "beats": [
          {
            "type": "main",
            "duration": 60,
            "description": "Continuous A-roll primary narrative with optional B-roll overlays."
          }
        ],
        "totalDuration": 60
      },
      "slotRequirements": {
        "workflow": "aroll_clean_then_broll",
        "slots": [
          {
            "slotId": "A1",
            "slotType": "a_roll_face",
            "priority": "required",
            "description": "Primary A-roll camera take (includes source audio)",
            "duration": { "min": 20, "target": 60, "max": 180 }
          },
          {
            "slotId": "B1",
            "slotType": "b_roll_illustration",
            "priority": "required",
            "description": "Required supporting B-roll (available after A-roll audio is cleaned)",
            "duration": { "min": 3, "target": 30, "max": 60 }
          },
          {
            "slotId": "B2",
            "slotType": "b_roll_illustration",
            "priority": "optional",
            "description": "Optional extra B-roll for variety",
            "duration": { "min": 3, "target": 20, "max": 60 }
          }
        ]
      },
      "personaTags": ["aroll-first", "facecam", "clean-audio", "optional-broll"],
      "niche": "general",
      "tone": "conversational"
    },
